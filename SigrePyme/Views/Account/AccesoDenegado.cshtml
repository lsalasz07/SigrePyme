@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-danger">
                <div class="card-body py-5">
                    <i class="bi bi-shield-x text-danger" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-danger">Acceso Denegado</h2>
                    <p class="text-muted mt-2">
                        No tienes los permisos necesarios para acceder a esta sección.<br />
                        Contacta al administrador si crees que esto es un error.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                        <i class="bi bi-house me-1"></i>Volver al Inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
