@model IEnumerable<(SigrePyme.Models.ApplicationUser Usuario, IList<string> Roles)>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people me-2"></i>Gestión de Usuarios</h2>
        <a asp-action="Register" class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i>Nuevo Usuario
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre Completo</th>
                            <th>Correo Electrónico</th>
                            <th>Rol Asignado</th>
                            <th>Fecha de Registro</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No hay usuarios registrados en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var (usuario, roles) in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@usuario.NombreCompleto</td>
                                    <td>@usuario.Email</td>
                                    <td>
                                        @foreach (var rol in roles)
                                        {
                                            var badgeClass = rol switch
                                            {
                                                "Administrador" => "bg-danger",
                                                "Gerente" => "bg-warning text-dark",
                                                "Vendedor" => "bg-success",
                                                "Almacenista" => "bg-info text-dark",
                                                _ => "bg-secondary"
                                            };
                                            <span class="badge @badgeClass me-1">@rol</span>
                                        }
                                        @if (!roles.Any())
                                        {
                                            <span class="badge bg-secondary">Sin rol</span>
                                        }
                                    </td>
                                    <td>@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
