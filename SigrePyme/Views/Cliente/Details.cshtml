@model SigrePyme.Models.Cliente
@{
    ViewData["Title"] = "Detalle de Cliente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Clientes</a></li>
                    <li class="breadcrumb-item active">@Model.NombreCompleto</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>@Model.NombreCompleto</h5>
                    @if (Model.Activo)
                    {
                        <span class="badge bg-light text-dark">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Correo Electrónico</p>
                            <p class="fw-semibold">
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            </p>
                        </div>

                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Teléfono</p>
                            <p class="fw-semibold">@(Model.Telefono ?? "No registrado")</p>
                        </div>

                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Empresa / Razón Social</p>
                            <p class="fw-semibold">@(Model.Empresa ?? "No registrada")</p>
                        </div>

                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Fecha de Registro</p>
                            <p class="fw-semibold">@Model.FechaRegistro.ToString("dd/MM/yyyy")</p>
                        </div>

                        <div class="col-12">
                            <p class="text-muted small mb-1">Dirección</p>
                            <p class="fw-semibold">@(Model.Direccion ?? "No registrada")</p>
                        </div>

                    </div>
                </div>

                <div class="card-footer d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </a>
                    @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Eliminar
                        </a>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
