@model IEnumerable<SigrePyme.Models.Cliente>
@{
    ViewData["Title"] = "Clientes";
}

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0"><i class="bi bi-people me-2"></i>Gestión de Clientes</h2>
            <small class="text-muted">Listado y administración de clientes</small>
        </div>
        @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-person-plus me-1"></i>Nuevo Cliente
            </a>
        }
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" id="buscador" class="form-control"
                       placeholder="Buscar por nombre, correo o empresa..." autocomplete="off" />
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaClientes">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Empresa</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-people fs-2 d-block mb-2"></i>
                                    No hay clientes registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@c.NombreCompleto</strong>
                                        @if (!string.IsNullOrEmpty(c.Direccion))
                                        {
                                            <br />
                                
                                            <small class="text-muted">@c.Direccion</small>
                                        }
                                    </td>
                                    <td>
                                        <a href="mailto:@c.Email" class="text-decoration-none">
                                            @c.Email
                                        </a>
                                    </td>
                                    <td>@(c.Telefono ?? "—")</td>
                                    <td>@(c.Empresa ?? "—")</td>
                                    <td class="text-center">
                                        @if (c.Activo)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@c.Id"
                                               class="btn btn-outline-info" title="Ver detalle">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@c.Id"
                                                   class="btn btn-outline-warning" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            @if (User.IsInRole("Administrador"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@c.Id"
                                                   class="btn btn-outline-danger" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const buscador = document.getElementById('buscador');
        const tbody    = document.querySelector('#tablaClientes tbody');

        buscador.addEventListener('input', function () {
            const q = this.value.trim();
            if (q.length < 2) { location.reload(); return; }

            fetch(`/Cliente/BuscarJson?q=${encodeURIComponent(q)}`)
                .then(r => r.json())
                .then(data => {
                    if (data.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted py-4">
                            Sin resultados para "<strong>${q}</strong>".</td></tr>`;
                        return;
                    }
                    tbody.innerHTML = data.map(c => `
                        <tr>
                            <td><strong>${c.nombreCompleto}</strong></td>
                            <td><a href="mailto:${c.email}">${c.email}</a></td>
                            <td>${c.telefono ?? '—'}</td>
                            <td>${c.empresa ?? '—'}</td>
                            <td class="text-center"><span class="badge bg-success">Activo</span></td>
                            <td class="text-center">
                                <a href="/Cliente/Details/${c.id}" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/Cliente/Edit/${c.id}" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>`).join('');
                });
        });
    </script>
}
