@model SigrePyme.Models.ProductoViewModel
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
                    <li class="breadcrumb-item active">Nuevo Producto</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Registrar Nuevo Producto</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label asp-for="SKU" class="form-label fw-semibold"></label>
                                <input asp-for="SKU" class="form-control text-uppercase"
                                       placeholder="Ej: PROD-001" />
                                <span asp-validation-for="SKU" class="text-danger small"></span>
                                <div class="form-text">Debe ser único en el sistema.</div>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                                <input asp-for="Nombre" class="form-control"
                                       placeholder="Nombre descriptivo del producto" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                                <textarea asp-for="Descripcion" class="form-control" rows="2"
                                          placeholder="Descripción opcional..."></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PrecioCosto" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₡</span>
                                    <input asp-for="PrecioCosto" class="form-control" type="number"
                                           step="0.01" min="0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="PrecioCosto" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PrecioVenta" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₡</span>
                                    <input asp-for="PrecioVenta" class="form-control" type="number"
                                           step="0.01" min="0" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="PrecioVenta" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="StockActual" class="form-label fw-semibold"></label>
                                <input asp-for="StockActual" class="form-control" type="number" min="0" />
                                <span asp-validation-for="StockActual" class="text-danger small"></span>
                                <div class="form-text">Se registrará como entrada inicial en el historial.</div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="StockMinimo" class="form-label fw-semibold"></label>
                                <input asp-for="StockMinimo" class="form-control" type="number" min="1" />
                                <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                                <div class="form-text">El sistema alertará cuando el stock baje de este valor.</div>
                            </div>

                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-lg me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-floppy me-1"></i>Guardar Producto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('SKU').addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    </script>
}
