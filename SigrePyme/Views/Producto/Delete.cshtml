@model SigrePyme.Models.Producto
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
                    <li class="breadcrumb-item active">Eliminar</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Confirmar Eliminación</h5>
                </div>

                <div class="card-body p-4 text-center">
                    <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">¿Está seguro de que desea eliminar este producto?</h5>
                    <p class="text-muted">Esta acción desactivará el producto del catálogo.</p>

                    <div class="card bg-light my-3 text-start">
                        <div class="card-body">
                            <p class="mb-1"><strong>SKU:</strong> <code>@Model.SKU</code></p>
                            <p class="mb-1"><strong>Nombre:</strong> @Model.Nombre</p>
                            <p class="mb-0"><strong>Stock actual:</strong> @Model.StockActual unidades</p>
                        </div>
                    </div>

                    @if (Model.Transacciones.Any())
                    {
                        <div class="alert alert-warning text-start">
                            <i class="bi bi-info-circle me-1"></i>
                            Este producto tiene <strong>@Model.Transacciones.Count transacción(es)</strong> registrada(s).
                            Solo se puede <strong>desactivar</strong>, no eliminar permanentemente.
                        </div>
                    }
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Sí, Eliminar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
