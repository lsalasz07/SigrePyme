@model SigrePyme.Models.Producto
@{
    ViewData["Title"] = "Detalle de Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
                    <li class="breadcrumb-item active">@Model.Nombre</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-box-seam me-2"></i>@Model.Nombre</h5>
                    <span class="badge bg-light text-dark fs-6">@Model.SKU</span>
                </div>

                <div class="card-body p-4">

                    @if (Model.TieneStockBajo)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Stock bajo.</strong> El stock actual (@Model.StockActual) está por debajo
                            del mínimo configurado (@Model.StockMinimo unidades).
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Descripción</p>
                            <p class="fw-semibold">@(Model.Descripcion ?? "Sin descripción.")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Estado</p>
                            @if (Model.Activo)
                            {
                                <span class="badge bg-success fs-6">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6">Inactivo</span>
                            }
                        </div>
                        <div class="col-md-4">
                            <p class="text-muted small mb-1">Precio de Costo</p>
                            <p class="fw-semibold fs-5">₡@Model.PrecioCosto.ToString("N2")</p>
                        </div>
                        <div class="col-md-4">
                            <p class="text-muted small mb-1">Precio de Venta</p>
                            <p class="fw-semibold fs-5 text-success">₡@Model.PrecioVenta.ToString("N2")</p>
                        </div>
                        <div class="col-md-4">
                            <p class="text-muted small mb-1">Margen</p>
                            @{
                                var margen = Model.PrecioCosto > 0
                                ? ((Model.PrecioVenta - Model.PrecioCosto) / Model.PrecioCosto * 100)
                                : 0;
                            }
                            <p class="fw-semibold fs-5 text-primary">@margen.ToString("N1")%</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Stock Actual</p>
                            <span class="badge @(Model.TieneStockBajo ? "bg-danger" : "bg-success") fs-4 px-3">
                                @Model.StockActual unidades
                            </span>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Stock Mínimo (Umbral)</p>
                            <p class="fw-semibold">@Model.StockMinimo unidades</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Fecha de Registro</p>
                            <p class="fw-semibold">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Volver
                    </a>
                    <a asp-action="Transacciones" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                        <i class="bi bi-clock-history me-1"></i>Historial
                    </a>
                    @if (User.IsInRole("Administrador") || User.IsInRole("Almacenista"))
                    {
                        <a asp-action="RegistrarMovimiento" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-left-right me-1"></i>Registrar Movimiento
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
