@model IEnumerable<SigrePyme.Models.TransaccionInventario>
@using SigrePyme.Models
@{
    ViewData["Title"] = "Historial de Transacciones";
    var producto = ViewBag.Producto as Producto;
}

<div class="container-fluid mt-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Catálogo</a></li>
            <li class="breadcrumb-item">
                <a asp-action="Details" asp-route-id="@producto!.Id">@producto.Nombre</a>
            </li>
            <li class="breadcrumb-item active">Historial</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">
                <i class="bi bi-clock-history me-2"></i>Historial de Inventario
            </h4>
            <small class="text-muted">
                <code>@producto.SKU</code> — @producto.Nombre |
                Stock actual:
                <strong class="@(producto.TieneStockBajo ? "text-danger" : "text-success")">
                    @producto.StockActual unidades
                </strong>
            </small>
        </div>
        @if (User.IsInRole("Administrador") || User.IsInRole("Almacenista"))
        {
            <a asp-action="RegistrarMovimiento" asp-route-id="@producto.Id" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Movimiento
            </a>
        }
    </div>

    @if (producto.TieneStockBajo)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Stock bajo:</strong> El stock actual (@producto.StockActual) está por debajo del
            umbral mínimo (@producto.StockMinimo unidades).
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th class="text-center">Tipo</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-center">Stock Resultante</th>
                            <th>Observación</th>
                            <th>Registrado por</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    No hay transacciones registradas para este producto.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var t in Model)
                            {
                                var (badgeClass, icono, signo) = t.Tipo switch
                                {
                                    TipoTransaccion.Entrada => ("bg-success", "bi-arrow-down-circle-fill", "+"),
                                    TipoTransaccion.Salida => ("bg-danger", "bi-arrow-up-circle-fill", "-"),
                                    _ => ("bg-warning text-dark", "bi-tools", "±")
                                };

                                <tr>
                                    <td>
                                        <span class="fw-semibold">@t.Fecha.ToString("dd/MM/yyyy")</span>
                                        <br /><small class="text-muted">@t.Fecha.ToString("HH:mm")</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @badgeClass">
                                            <i class="bi @icono me-1"></i>@t.Tipo
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold fs-5">
                                        <span class="@(t.Tipo == TipoTransaccion.Entrada ? "text-success" : "text-danger")">
                                            @signo@t.Cantidad
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary fs-6">@t.StockResultante</span>
                                    </td>
                                    <td>@(t.Observacion ?? "—")</td>
                                    <td>
                                        <i class="bi bi-person-circle me-1 text-muted"></i>
                                        @t.UsuarioRegistro
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver al Catálogo
        </a>
    </div>
</div>
