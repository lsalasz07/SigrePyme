<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SIGRE-PYME</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root { --bs-primary: #1a3a5c; }
        body  { background-color: #f4f6f9; }

        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .navbar { background: linear-gradient(135deg, #1a3a5c, #2e6da4) !important; }

        .nav-link.active { background: rgba(255,255,255,.15); border-radius: 6px; }
    </style>
</head>
<body>

    <!-- ===== NAVBAR SUPERIOR ===== -->
    <nav class="navbar navbar-dark navbar-expand-md shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-building me-1"></i>SIGRE-PYME
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMenu" aria-controls="navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Inicio
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Producto" asp-action="Index">
                                <i class="bi bi-box-seam me-1"></i>Catálogo
                            </a>
                        </li>

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="ListarUsuarios">
                                    <i class="bi bi-people me-1"></i>Usuarios
                                </a>
                            </li>
                        }
                    }
                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main class="pb-5">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="text-center text-muted py-3 border-top bg-white small">
        &copy; @DateTime.Now.Year SIGRE-PYME &mdash; Sistema Integral de Gestión de Recursos
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
