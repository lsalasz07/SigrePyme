@using Microsoft.AspNetCore.Identity
@inject SignInManager<SigrePyme.Models.ApplicationUser> SignInManager
@inject UserManager<SigrePyme.Models.ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);

    if (currentUser == null)
    {
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-light">
                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
            </button>
        </form>
    }
    else
    {
        var roles = await UserManager.GetRolesAsync(currentUser);
        var rol = roles.FirstOrDefault() ?? "Usuario";

        <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small">
                <i class="bi bi-person-circle me-1"></i>@currentUser.NombreCompleto
                <span class="badge bg-light text-dark ms-1">@rol</span>
            </span>

            @if (User.IsInRole("Administrador"))
            {
                <a asp-controller="Account" asp-action="ListarUsuarios"
                   class="btn btn-sm btn-outline-light">
                    <i class="bi bi-people me-1"></i>Usuarios
                </a>
            }

            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-light">
                    <i class="bi bi-box-arrow-right me-1"></i>Salir
                </button>
            </form>
        </div>
    }
}
else
{
    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-light">
        <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
    </a>
}
